<?xml version='1.0'?>
<!--
  Moosinsa м„ёнҠёмһҘ л§һм¶Ө bringup launch
  - vendor/pinky_navigationмқҳ localization_launch, navigation_launchлҘј include
  - мҡ°лҰ¬ nav2_params.yamlлЎң нҢҢлқјлҜён„° мҳӨлІ„лқјмқҙл“ң
  - keepout filter м„ңлІ„ м¶”к°Җ
  - м»ӨмҠӨн…Җ BT XML кІҪлЎң мЈјмһ…
-->
<launch>
    <set_env name="RCUTILS_LOGGING_BUFFERED_STREAM" value="1"/>

    <arg name="namespace" default=""/>
    <arg name="map" default=""/>
    <arg name="use_sim_time" default="False"/>
    <!-- вҳ… н•өмӢ¬: vendorк°Җ м•„лӢҢ мҡ°лҰ¬ paramsлҘј кё°ліёк°’мңјлЎң мӮ¬мҡ© -->
    <arg name="params_file" default="$(find-pkg-share moosinsa_navigation)/params/nav2_params.yaml"/>
    <arg name="autostart" default="True"/>
    <arg name="container_name" default="nav2_container"/>
    <arg name="use_composition" default="True"/>
    <arg name="use_respawn" default="False"/>
    <arg name="log_level" default="info"/>

    <!-- keepout filter м„ңлІ„лҸ„ lifecycleм—җ нҸ¬н•Ё -->
    <arg name="lifecycle_nodes_local" default="['map_server', 'amcl', 'filter_mask_server', 'costmap_filter_info_server']"/>
    <arg name="lifecycle_nodes_nav" default="['controller_server',
                       'planner_server',
                       'behavior_server',
                       'bt_navigator',
                       'waypoint_follower',
                       'velocity_smoother']"/>

    <group>
        <push-ros-namespace namespace="$(var namespace)"/>

        <node pkg="rclcpp_components" exec="component_container_isolated" name='$(var container_name)' output="screen" args="--ros-args --log-level $(var log_level)">
            <param from="$(var params_file)"/>
            <param name='map' value="$(var map)"/>
            <param name='autostart' value="$(var autostart)"/>
            <param name='use_sim_time' value="$(var use_sim_time)"/>
            <!-- вҳ… м»ӨмҠӨн…Җ BT XML кІҪлЎң мЈјмһ… -->
            <param name='default_nav_to_pose_bt_xml'
                   value="$(find-pkg-share moosinsa_navigation)/behavior_trees/navigate_to_pose_custom.xml"/>
            <remap from="/tf" to="tf"/>
            <remap from="/tf_static" to="tf_static"/>
        </node>

        <!-- вҳ… keepout filter mask м„ңлІ„ -->
        <node pkg="nav2_map_server" exec="map_server" name="filter_mask_server" output="screen">
            <param name="yaml_filename"
                   value="$(find-pkg-share moosinsa_navigation)/maps/keepout_mask.yaml"/>
            <param name="topic_name" value="keepout_filter_mask"/>
            <param name="frame_id" value="map"/>
            <param name="use_sim_time" value="$(var use_sim_time)"/>
        </node>

        <!-- вҳ… costmap filter info м„ңлІ„ -->
        <node pkg="nav2_map_server" exec="costmap_filter_info_server" name="costmap_filter_info_server" output="screen">
            <param name="type" value="0"/>
            <param name="filter_info_topic" value="/costmap_filter_info"/>
            <param name="mask_topic" value="/keepout_filter_mask"/>
            <param name="base" value="0.0"/>
            <param name="multiplier" value="1.0"/>
            <param name="use_sim_time" value="$(var use_sim_time)"/>
        </node>

        <!-- vendorмқҳ localization launchлҘј include (мҡ°лҰ¬ paramsлЎң мҳӨлІ„лқјмқҙл“ң) -->
        <include file="$(find-pkg-share pinky_navigation)/launch/localization_launch.xml">
            <arg name="params_file" value="$(var params_file)"/>
            <arg name="map" value="$(var map)"/>
            <arg name="use_sim_time" value="$(var use_sim_time)"/>
            <arg name="autostart" value="$(var autostart)"/>
            <arg name="use_composition" value="$(var use_composition)"/>
            <arg name="use_respawn" value="$(var use_respawn)"/>
            <arg name="container_name" value="$(var container_name)"/>
            <arg name='lifecycle_nodes' value="$(var lifecycle_nodes_local)"/>
        </include>

        <!-- vendorмқҳ navigation launchлҘј include (мҡ°лҰ¬ paramsлЎң мҳӨлІ„лқјмқҙл“ң) -->
        <include file="$(find-pkg-share pinky_navigation)/launch/navigation_launch.xml">
            <arg name="params_file" value="$(var params_file)"/>
            <arg name="use_sim_time" value="$(var use_sim_time)"/>
            <arg name="autostart" value="$(var autostart)"/>
            <arg name="use_composition" value="$(var use_composition)"/>
            <arg name="use_respawn" value="$(var use_respawn)"/>
            <arg name="container_name" value="$(var container_name)"/>
            <arg name='lifecycle_nodes' value="$(var lifecycle_nodes_nav)"/>
        </include>
    </group>
</launch>
