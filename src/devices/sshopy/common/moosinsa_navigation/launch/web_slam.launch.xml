<?xml version='1.0'?>
<!--
  Moosinsa Web SLAM launch
  - vendor의 nav2_web_server를 사용
  - 우리 bringup + mapper_params로 오버라이드
-->
<launch>
    <arg name="use_sim_time" default="False"/>
    <arg name="ip" default="192.168.1.112"/>
    <arg name="port" default="8080"/>
    <arg name="params_file" default="$(find-pkg-share moosinsa_navigation)/params/nav2_params.yaml"/>
    <arg name="slam_params_file" default="$(find-pkg-share moosinsa_navigation)/params/mapper_params.yaml"/>

    <!-- vendor의 웹 서버 재사용 -->
    <node pkg="pinky_navigation" exec="nav2_web_server.py" name="nav2_web_server" output="screen">
        <param name="ip" value="$(var ip)"/>
        <param name="port" value="$(var port)"/>
    </node>

    <!-- 우리 bringup (우리 params 적용) -->
    <include file="$(find-pkg-share moosinsa_navigation)/launch/bringup.launch.xml">
        <arg name="params_file" value="$(var params_file)"/>
        <arg name="use_sim_time" value="$(var use_sim_time)"/>
    </include>

    <!-- 우리 SLAM (우리 mapper_params 적용) -->
    <include file="$(find-pkg-share moosinsa_navigation)/launch/map_building.launch.xml">
        <arg name="slam_params_file" value="$(var slam_params_file)"/>
        <arg name="use_sim_time" value="$(var use_sim_time)"/>
    </include>
</launch>
