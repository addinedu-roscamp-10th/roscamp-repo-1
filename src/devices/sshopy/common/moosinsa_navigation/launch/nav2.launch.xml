<?xml version='1.0'?>
<!--
  Moosinsa Nav2 실행 (맵 지정)
  - 이미 만들어둔 맵으로 네비게이션만 실행
  - ros2 launch moosinsa_navigation nav2.launch.xml map:=<맵경로>
-->
<launch>
    <arg name="use_sim_time" default="False"/>
    <arg name="map" default="$(find-pkg-share moosinsa_navigation)/maps/mapgood.yaml"/>
    <arg name="params_file" default="$(find-pkg-share moosinsa_navigation)/params/nav2_params.yaml"/>

    <include file="$(find-pkg-share moosinsa_navigation)/launch/bringup.launch.xml">
        <arg name="params_file" value="$(var params_file)"/>
        <arg name="map" value="$(var map)"/>
        <arg name="use_sim_time" value="$(var use_sim_time)"/>
    </include>
</launch>
